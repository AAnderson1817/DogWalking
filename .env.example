# PawTrail environment keys (mirrors the HANDOFF.md table).
# Copy the VITE_* block to app/.env.local; set edge function secrets with
# `supabase secrets set`; export LOCAL_DB_URL in your shell profile.
# No secrets are ever committed.

# ── frontend (app/.env.local) ────────────────────────────────────────────
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
# Optional; MapView falls back to the SVG polyline renderer when absent.
VITE_MAPBOX_TOKEN=

# ── edge function secrets ────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 32-byte base64; generate with: openssl rand -base64 32
VAULT_MASTER_KEY=
# Optional; phase 08 email delivery is silently skipped when absent.
RESEND_API_KEY=

# ── local development shell ──────────────────────────────────────────────
LOCAL_DB_URL=postgresql://postgres@127.0.0.1:54322/postgres
